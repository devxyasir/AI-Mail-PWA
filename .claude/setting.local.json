{
    "env": {
        "ANTHROPIC_BASE_URL": "https://openrouter.ai/api",
        "ANTHROPIC_AUTH_TOKEN": "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",
        "ANTHROPIC_API_KEY": "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",
        "ANTHROPIC_MODEL": "minimax/minimax-m2.5:free"
    },
    "permissions": {
        "allow": [
            "Bash(npm run lint)",
            "Bash(npm run test)",
            "Bash(npm run build)",
            "Bash(npm run test:e2e)",
            "Bash(npm run test:all)",
            "Bash(npm run dev)",
            "Bash(git add *)",
            "Bash(git commit *)",
            "Bash(git status)",
            "Bash(git diff)",
            "Bash(mkdir *)",
            "Bash(touch *)",
            "Bash(cat *)",
            "Bash(ls *)",
            "Bash(grep *)",
            "Bash(node .claude/hooks/*)"
        ],
        "deny": [
            "Bash(rm -rf *)",
            "Bash(sudo *)",
            "Bash(curl * | bash)",
            "Bash(wget * | sh)",
            "Bash(npx * --yes *)"
        ]
    },
    "hooks": {
        "PostToolUse": [
            {
                "matcher": "Edit|Write|MultiEdit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node .claude/hooks/post-edit-quality-check.js"
                    }
                ]
            }
        ],
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node .claude/hooks/block-dangerous-commands.js"
                    },
                    {
                        "type": "command",
                        "command": "node .claude/hooks/scan-secrets.js"
                    }
                ]
            }
        ]
    }
}